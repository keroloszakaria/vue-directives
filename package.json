{
  "name": "vue-directives",
  "version": "1.0.0",
  "description": "86+ tree-shakable, fully typed Vue 3 & Nuxt 3/4 custom directives — click-outside, tooltip, copy, longpress, ripple, lazy-load, virtual-scroll, drag, swipe, focus-trap, and more",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "prepublishOnly": "npm run build",
    "deploy": "surge docs/.vitepress/dist vue-directives.surge.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-directives",
    "nuxt",
    "nuxt3",
    "nuxt4",
    "directives",
    "custom-directives",
    "typescript",
    "tree-shaking",
    "click-outside",
    "tooltip",
    "copy",
    "clipboard",
    "longpress",
    "ripple",
    "lazy-load",
    "virtual-scroll",
    "drag-and-drop",
    "swipe",
    "gesture",
    "focus-trap",
    "intersection-observer",
    "resize-observer",
    "debounce",
    "throttle",
    "scroll",
    "animation",
    "accessibility",
    "a11y",
    "aria"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.3.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "author": {
    "name": "Kerolos Zakaria",
    "email": "kerolozakaria2@gmail.com",
    "url": "https://keroloszakaria.surge.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keroloszakaria/vue-directives.git"
  },
  "bugs": {
    "url": "https://github.com/keroloszakaria/vue-directives/issues"
  },
  "homepage": "https://vue-directives.surge.sh",
  "license": "MIT"
}